# ============================================================================
# GTS Meet - Janus Environment Configuration
# ============================================================================
# This repo can be used in two ways:
# 1. standalone: users open this repo's dashboard at / and create or join rooms directly
# 2. separate meeting service: external apps call this repo's backend API and then
#    send users back to this repo's frontend for /room/:roomId?token=...
# ============================================================================

# PostgreSQL (backend database)
POSTGRES_USER=janus_user
POSTGRES_PASSWORD=janus_password
POSTGRES_DB=janus_classroom

# Backend server
PORT=8080
DATABASE_URL=postgresql://janus_user:janus_password@db:5432/janus_classroom?schema=public

# Janus backend integration
# Default matches the Docker Compose bridge gateway because Janus runs in host network mode.
JANUS_HTTP_URL=http://172.28.0.1:8088/janus

# Janus HTTP API auth. Leave empty unless Janus is configured to require apisecret.
JANUS_API_SECRET=

# Room and token API protection.
# External backends should send this value in the x-api-secret header.
API_SHARED_SECRET=change-me

# Participant join token signing
JWT_SECRET=change-me
JWT_EXPIRY=2h

# Additional browser origins allowed by backend CORS, comma-separated.
# Example: https://admin.example.com,https://candidate.example.com
CORS_ORIGINS=

# Janus WebRTC gateway
# Set to your public or LAN IP for WebRTC NAT traversal. Leave empty to disable.
JANUS_NAT_1_1_IP=

# Frontend build-time
# Leave empty to use same-origin proxy (/api and /janus-ws) in Docker/Nginx and Vite dev server.
VITE_BACKEND_URL=
VITE_JANUS_WS_URL=

# Vite dev proxy targets (used by frontend/vite.config.js)
VITE_PROXY_BACKEND_TARGET=http://localhost:8080
VITE_PROXY_JANUS_WS_TARGET=ws://localhost:8188

# External app integration reference only
# These values are not consumed by this repo directly. Copy them into external apps.
# Example for a Dockerized local stack:
JANUS_API_URL=http://localhost:8080
JANUS_FRONTEND_URL=http://localhost:3000

# Optional WebRTC ICE overrides for restricted networks.
# If VITE_ICE_SERVERS_JSON is set, it takes precedence over individual TURN vars.
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=pass
