# PostgreSQL
POSTGRES_USER=janus_user
POSTGRES_PASSWORD=janus_password
POSTGRES_DB=janus_classroom

# Backend
PORT=8080
DATABASE_URL=postgresql://janus_user:janus_password@db:5432/janus_classroom?schema=public
JANUS_API_SECRET=your_secret_here
JANUS_ADMIN_SECRET=your_admin_secret_here

# Janus WebRTC
# Set to your host/LAN IP for WebRTC NAT traversal. Leave empty to disable.
JANUS_NAT_1_1_IP=

# Frontend (build-time)
# Leave empty to use same-origin proxy (/api and /janus-ws) in Docker/Nginx and Vite dev server.
VITE_BACKEND_URL=
VITE_JANUS_WS_URL=

# Vite dev proxy targets (used by frontend/vite.config.js)
VITE_PROXY_BACKEND_TARGET=http://localhost:8080
VITE_PROXY_JANUS_WS_TARGET=ws://localhost:8188

# Optional WebRTC ICE overrides for restricted networks.
# If VITE_ICE_SERVERS_JSON is set, it takes precedence.
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=pass
