# Frontend environment configuration for Vite
# Copy this to .env.local and customize for your environment

# Backend URL for API requests (optional, defaults to same-origin /api)
# VITE_BACKEND_URL=http://localhost:8080

# API Shared Secret - must match backend's API_SHARED_SECRET if configured
# Leave blank if backend doesn't require authentication for room creation
VITE_API_SHARED_SECRET=

# Proxy backend target for development (used by vite.config.js)
# VITE_PROXY_BACKEND_TARGET=http://localhost:8080

# Proxy Janus WebSocket for development (used by vite.config.js)
# VITE_PROXY_JANUS_WS_TARGET=ws://localhost:8188
